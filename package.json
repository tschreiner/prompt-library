{
  "name": "prompt-library",
  "version": "0.1.0",
  "private": false,
  "description": "Static-first prompt library built with React, TypeScript, and YAML-based prompt templates.",
  "license": "MIT",
  "author": "Tedd Schreiner <info@teddschreiner.de>",
  "homepage": "https://tschreiner.github.io/prompt-library/",
  "bugs": {
    "url": "https://github.com/tschreiner/prompt-library/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tschreiner/prompt-library.git"
  },
  "keywords": [
    "prompts",
    "prompt-library",
    "react",
    "typescript",
    "vite",
    "yaml"
  ],
  "type": "module",
  "scripts": {
    "check": "npm run prompts:check && npm run lint && npm run typecheck && npm run test",
    "dev": "vite",
    "build": "npm run prompts:render && tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prompts:check": "tsx scripts/render-prompts.ts",
    "prompts:render": "tsx scripts/render-prompts.ts",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  }
}
